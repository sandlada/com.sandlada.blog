---
import { type CollectionEntry, getCollection } from 'astro:content';
import { render } from 'astro:content';
import { Article } from '../../modules/article/Article';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

interface Props extends CollectionEntry<'articles'> {}

export async function getStaticPaths() {
    const posts = await getCollection('articles');
    return posts.map((post) => ({
        params: { id: post.data.id },
        props: post,
    }));
}

const { data: { id, references } } = Astro.props;
const relatedArticles = await Article.GetRelatedArticles(id);
const resolvedReferences = await Article.GetReferencedReferences(references);
const { Content, headings } = await render(Astro.props);
---

<ArticleLayout
    entry={Astro.props}
    {Content}
    {headings}
    {relatedArticles}
    {resolvedReferences}
/>
