---
import "@fontsource-variable/noto-sans-tc"
import "@fontsource-variable/noto-serif-tc"
---

<style is:global>
    :root[data-font-style="sans"] {
        font-family: "Noto Sans TC Variable";
        --md-ref-typeface-brand: "Noto Sans TC Variable";
        --md-ref-typeface-plain: "Noto Sans TC Variable";
    }
    :root[data-font-style="serif"] {
        font-family: "Noto Serif TC Variable";
        --md-ref-typeface-brand: "Noto Serif TC Variable";
        --md-ref-typeface-plain: "Noto Serif TC Variable";
    }
</style>
