---
import "@fontsource-variable/noto-sans"
import "@fontsource-variable/noto-serif"

import notoSansWoff2 from "@fontsource-variable/noto-sans/files/noto-sans-latin-wght-normal.woff2";
import notoSerifWoff2 from "@fontsource-variable/noto-serif/files/noto-serif-latin-wght-normal.woff2";
---

<link rel="preload" href={notoSansWoff2} as="font" type="font/woff2" crossorigin />
<link rel="preload" href={notoSerifWoff2} as="font" type="font/woff2" crossorigin />

<style is:global define:vars={{ notoSansWoff2, notoSerifWoff2 }}>

    @font-face {
        font-family: "Noto Sans Variable";
        src: url(var(--notoSansWoff2)) format('woff2');
        font-weight: 100 900;
        font-style: normal;
        font-display: swap;
    }

    @font-face {
        font-family: "Noto Serif Variable";
        src: url(var(--notoSerifWoff2)) format('woff2');
        font-weight: 100 900;
        font-style: normal;
        font-display: swap;
    }

    :root[data-font-style="sans"] {
        font-family: "Noto Sans Variable";
        --md-ref-typeface-brand: "Noto Sans Variable";
        --md-ref-typeface-plain: "Noto Sans Variable";
    }
    :root[data-font-style="serif"] {
        font-family: "Noto Serif Variable";
        --md-ref-typeface-brand: "Noto Serif Variable";
        --md-ref-typeface-plain: "Noto Serif Variable";
    }
</style>
