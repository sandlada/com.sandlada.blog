---
import "@fontsource-variable/noto-sans-sc"
import "@fontsource-variable/noto-serif-sc"

---

<style is:global>
    :root[data-font-style="sans"] {
        font-family: "Noto Sans SC Variable";
        --md-ref-typeface-brand: "Noto Sans SC Variable";
        --md-ref-typeface-plain: "Noto Sans SC Variable";
    }
    :root[data-font-style="serif"] {
        font-family: "Noto Serif SC Variable";
        --md-ref-typeface-brand: "Noto Serif SC Variable";
        --md-ref-typeface-plain: "Noto Serif SC Variable";
    }
</style>
