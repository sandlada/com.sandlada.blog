<main class="article-page-container">
    <slot></slot>
</main>

<style>

    .article-page-container {
        box-sizing: border-box;
        width: 100%;
        max-width: 100dvw;
        height: 100%;
        display: flow-root;
        position: relative;
        overflow: clip;

        transition-property: padding;
        transition-duration: 50ms;

        padding-top: 12px;
        padding-left: 12px;
        padding-right: 12px;
        @media (min-width: 600px) {
            padding-left: 24px;
            padding-right: 24px;
        }
        @media (min-width: 720px) {
        }
        @media (min-width: 840px) {
        }

        @media (min-width: 1200px) {
            max-width: 1200px;
            margin-left: auto;
            margin-right: auto;
            padding-left: 72px;
            padding-right: 72px;
        }
        @media (min-width: 1396px) {
            max-width: 1200px;
            padding-left: 12px;
            padding-right: 12px;
        }
    }
</style>
