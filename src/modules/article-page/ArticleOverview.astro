---
import type { TArticle } from '../../content.config'


interface Props {
    overview: TArticle['overview']
}

const { overview } = Astro.props
---

<div class="article-ai-overview">
    <h3 class="title title-medium">Overview</h3>
    <p class="sub-title label-small">Overview is generated by AI and may contain errors.</p>
    <span class="content-wrapper" id="ai-overview-content-wrapper">
        <p class="content body-medium">{overview}</p>
    </span>
    <mdc-button variant="outlined" id="ai-overview-expand-button" data-state="collapsed">
        <span id="ai-overview-expand-button-label">Expand</span>
    </mdc-button>

    <span class="background" aria-hidden="true"></span>

</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const button = document.querySelector(`#ai-overview-expand-button`) as HTMLButtonElement | null
        const buttonLabel = button?.querySelector(`#ai-overview-expand-button-label`) as HTMLElement | null
        const contentWrapper = document.querySelector(`#ai-overview-content-wrapper`) as HTMLElement | null

        if(!button || !buttonLabel || !contentWrapper) {
            return
        }

        contentWrapper.style.setProperty('--_max-height', `64px`)

        button.addEventListener('click', () => {
            if(button.dataset.state === 'collapsed') {
                buttonLabel.textContent = 'Collapse'
                button.dataset.state = 'expanded'
                contentWrapper.style.setProperty('--_max-height', `${contentWrapper.scrollHeight}px`)
            } else {
                buttonLabel.textContent = 'Expand'
                button.dataset.state = 'collapsed'
                contentWrapper.style.setProperty('--_max-height', `64px`)
            }
        })
    })
</script>

<style>
    .article-ai-overview {
        position: relative;
        border-radius: 24px;
        display: flow-root;
        box-sizing: border-box;
        overflow: clip;
        margin-block: 12px;

        &>.title,
        &>.sub-title,
        & .content,
        & mdc-button {
            color: var(--md-sys-color-primary);
            margin: 0;
            box-sizing: border-box;
            margin-inline: 24px;
        }

        &>.title{
            margin-block-start: 24px;
            margin-block-end: 4px;
        }
        &>.sub-title {
            margin-block-start: 4px;
            margin-block-end: 16px;
        }
        & .content {
            margin-block-start: 4px;
            margin-block-end: 24px;
        }
        & mdc-button {
            margin-block-start: 24px;
            margin-block-end: 24px;
        }

        &>.content-wrapper {
            display: grid;
            overflow: clip;
            grid-template-rows: 1fr;
            transition-duration: 500ms;
            transition-property: max-height, mask-size;
            mask-image: linear-gradient(to bottom, var(--md-sys-color-primary) 50%, transparent 100%);
        }
        &:has(mdc-button[data-state="collapsed"]) .content-wrapper {
            transition-timing-function: cubic-bezier(0.05, 0.7, 0.1, 1.0);
            max-height: var(--_max-height);
            mask-size: 100% 100%;
        }
        &:has(mdc-button:not([data-state="collapsed"])) .content-wrapper {
            transition-timing-function: cubic-bezier(0.2, 0.0, 0, 1.0);
            max-height: var(--_max-height);
            mask-size: 100% 200%;
        }
        
        & mdc-button {
            display: flex;
            justify-content: center;
        }

        &>.background {
            position: absolute;
            inset: 0;
            z-index: -1;
            background: linear-gradient(to bottom, var(--md-sys-color-primary-container) 30%, transparent 80%);
            opacity: 0.18;
        }
    }
</style>