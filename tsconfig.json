{
    "compilerOptions": {
        "allowJs": true,
        "jsx": "preserve",
        "lib": [
            "ESNext",
            "DOM",
            "DOM.AsyncIterable",
            "DOM.Iterable"
        ],
        "moduleResolution": "bundler",
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "plugins": [
            {
                "name": "@astrojs/ts-plugin"
            }
        ],
        "strictNullChecks": true
    },
    "exclude": [
        "dist",
        "public/vendor"
    ],
    "extends": "astro/tsconfigs/strictest",
    "include": [
        ".astro/types.d.ts",
        "**/*",
    ]
}
